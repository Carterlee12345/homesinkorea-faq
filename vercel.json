{
  "functions": {
    "api/*.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/channeltalk-digest",
      "schedule": "10 1 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/deposit-form", "destination": "/deposit-form.html" },
    { "source": "/review", "destination": "/review.html" },
    { "source": "/shop", "destination": "/upsell.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
